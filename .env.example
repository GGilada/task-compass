AIRTABLE_TOKEN=pat_your_private_airtable_token
AIRTABLE_SOURCES=Tasks|app_your_base_id|Tasks|tasks;Projects|app_your_base_id|Projects|projects;Things Done|app_your_base_id|Things that I did|activity
APP_ACCESS_CODE=choose-a-private-code

